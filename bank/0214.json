      "preposition_differs"
    ],
    "interference": {
      "es_to_it": "One letter: Italian lo meno, Spanish lo menoS. Dropping the s is the tell in the other direction too.",
      "it_to_es": "Adding the Spanish -s gives 'per lo menos' — not Italian."
    }
